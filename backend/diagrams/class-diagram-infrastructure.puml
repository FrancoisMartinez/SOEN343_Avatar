@startuml "Infrastructure — Partial Design Model"

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontSize 10
skinparam classFontSize 11
skinparam nodesep 10
skinparam ranksep 20

title Infrastructure (Partial Design Model)

' === ROW 1 ===
package "Repositories (1/2)" #F0FFF0 {
    interface UserRepository {
        + findByEmail(String) : Optional<User>
        + existsByEmail(String) : boolean
    }

    interface LearnerRepository
    interface InstructorRepository
    interface CarProviderRepository

    interface CarRepository {
        + findByProviderId(Long) : List<Car>
    }
}

package "Security" #FFF0F5 {
    class JwtUtil {
        + generateToken(Long, String) : String
        + validateToken(String) : Claims
    }

    class SecurityConfig {
        + filterChain(HttpSecurity) : SecurityFilterChain
        + passwordEncoder() : PasswordEncoder
    }
}

' === ROW 2 ===
package "Repositories (2/2)" #F0FFF0 {
    interface BookingRepository {
        + findActiveBookingsByCarAndDate(Long, LocalDate) : List<Booking>
        + findByLearnerIdOrderByDateDesc(Long) : List<Booking>
    }

    interface AvailabilitySlotRepository {
        + findByCarIdOrderByDayOfWeekAscStartMinuteAsc(Long) : List<AvailabilitySlot>
        + deleteByCarId(Long) : void
    }

    interface DrivingRouteRepository
    interface TransitRouteRepository
}

package "Adapters" #FFF5F0 {
    class OSRMAdapter {
        + getDirections(double, double, double, double, TransportMode) : RouteResult
    }

    class HereTransitAdapter {
        + getTransitDirections(double, double, double, double) : RouteResult
    }

    class OverpassAdapter {
        + getParkingNearby(double, double, double) : List<ParkingSpot>
    }

    class GoogleMapsAdapter
}

' Force 2-row layout
"Repositories (1/2)" -[hidden]down-> "Repositories (2/2)"
"Security" -[hidden]down-> "Adapters"

@enduml
